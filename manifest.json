{
  "manifest_version": 3,
  "name": "Hockey Nation OVR Calculator",
  "description": "Calculates player's min and max potential\nhttps://github.com/mcsharland/hockeynation",
  "version": "1.5.0",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["https://hockey-nation.com/*"],
      "js": ["dist/interceptor.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["https://hockey-nation.com/*"],
      "js": ["dist/contentScript.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  }
}
