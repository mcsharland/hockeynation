{
	"manifest_version": 3,
	"name": "Hockey Nation OVR Calculator",
	"description": "Calculates player's min and max potential on various pages",
	"version": "1.5.4",
	"permissions": [],
	"content_scripts": [
		{
			"matches": ["https://hockey-nation.com/*"],
			"js": ["dist/interceptor.js"],
			"world": "MAIN",
			"run_at": "document_start"
		},
		{
			"matches": ["https://hockey-nation.com/*"],
			"js": ["dist/contentScript.js"],
			"run_at": "document_start"
		}
	],
	"web_accessible_resources": [
		{
			"resources": ["images/flags/*.png", "images/special-skills/*.svg"],
			"matches": ["https://hockey-nation.com/*"]
		}
	],
	"icons": {
		"16": "images/icon16.png",
		"48": "images/icon48.png",
		"128": "images/icon128.png"
	}
}
