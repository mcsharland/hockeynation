{
	"compilerOptions": {
		"strict": true,
		"module": "ESNext",
		"moduleResolution": "bundler",
		"isolatedModules": true,
		"types": ["chrome"],
		"target": "ES2022",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true
	}
}
